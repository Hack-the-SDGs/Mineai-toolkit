{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://localhost:9000/v1",
        "apiKey": "dummy"
      },
      "models": {
        "Qwen3.6-35B-A3B": {
          "name": "Qwen3.6 35B-A3B (local)",
          "limit": { "context": 152406, "output": 16384 }
        }
      }
    },
    "llamacpp2": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local, port 57413)",
      "options": {
        "baseURL": "http://localhost:9000/v1",
        "apiKey": "dummy"
      },
      "models": {
        "Qwen3.6-27B-UD-Q4_K_XL.gguf": {
          "name": "Qwen3.6 27B UD-Q4_K_XL (local)",
          "limit": { "context": 130816, "output": 16384 }
        }
      }
    }
  },
  "mcp": {
    "mineai-toolkit": {
      "type": "local",
      "command": ["PATH_TO_YOUE_ENV", "PATH_TO_YOUR_MCP_SERVER_START_FILE"],
      "enabled": true,
      "environment": {
        "SOME_VAR": "value"
      }
    }
  }
}
